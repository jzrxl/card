---
const {name, position, aboutMe, linkedin, github, facebook, email, cvLink, profileImage } = Astro.props;
import '../styles/card.css';
---

<canvas id="starCanvas"></canvas>
<div class="cursor-dot"></div>
<div class="cursor-outline"></div>

<div class="container">
    <div class="main-wrapper reveal">
        <div class="card-container">
            <div class="descripcion">
                <div class="name-status">
                    <h1>{name}</h1>
                    <div class="status-indicator">
                        <span class="status-dot"></span>
                        <span class="status-pulse"></span>
                    </div>
                </div>
                
                <div class="title-container">
                    <h2 id="typewriter-title" data-text={position}></h2>
                </div>
                
                <div class="about-container">
                    <p class="about-text" set:html={aboutMe}></p>
                </div>
                
                <div class="social-footer">
                    <div class="icons">
                        {facebook && (
                            <a href={facebook} class="social-icon" target="_blank" data-tooltip="Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                        )}
                        {github && (
                            <a href={github} class="social-icon" target="_blank" data-tooltip="GitHub">
                                <i class="bi bi-github"></i>
                            </a>
                        )}
                        {linkedin && (
                            <a href={linkedin} class="social-icon" target="_blank" data-tooltip="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                        )}
                        {cvLink && (
                            <a href={cvLink} class="social-icon" target="_blank" data-tooltip="Download CV">
                                <i class="bi bi-file-earmark-arrow-down"></i>
                            </a>
                        )}
                        {email && (
                            <div class="social-icon copy-email-btn" data-email={email} role="button" data-tooltip="Click to Copy Email">
                                <i class="bi bi-envelope-at-fill"></i>
                            </div>
                        )}
                    </div>
                </div>
            </div>
            <div class="image">
                <div class="img-wrapper">
                    <img src={profileImage} alt={name}>
                </div>
            </div>
        </div>

        <div id="skills-panel" class="skills-panel">
            <div class="panel-inner">
                <div class="tech-stack">
                    <span class="tag">Hardware</span>
                    <span class="tag">Windows</span>
                    <span class="tag">Networking</span>
                    <span class="tag">Software</span>
                    <span class="tag">Troubleshooting</span>
                    <span class="tag">SysConfig</span>
                    <span class="tag">OS</span>
                    <span class="tag">LAN</span>
                    <span class="tag">IT Support</span>
                </div>
            </div>
        </div>

        <div class="trigger-wrapper">
            <button id="toggle-skills" class="skills-cta">
                <i class="bi bi-chevron-down arrow-icon"></i>
                <span id="cta-text">Click to view my skills</span>
                <i class="bi bi-chevron-down arrow-icon"></i>
            </button>
        </div>
    </div>
</div>

<script>
  function initAll() {
    console.clear();
    console.log("%cHey there🙋‍♂️", "font-weight:bold; font-size:24px; color:#00f2ff; text-shadow: 2px 2px 0px #00666b;");

    const canvas = document.getElementById('starCanvas') as HTMLCanvasElement;
    const dot = document.querySelector('.cursor-dot') as HTMLElement;
    const outline = document.querySelector('.cursor-outline') as HTMLElement;
    
    // --- Starfield with Permanent Displacement ---
    if (canvas) {
        const ctx = canvas.getContext('2d')!;
        let particles: any[] = [];
        const mouse = { x: -1000, y: -1000, radius: 130 };

        const resize = () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            initParticles();
        };

        class Particle {
            x: number; y: number; size: number; density: number;
            vx: number; vy: number;

            constructor(x: number, y: number) {
                this.x = x; this.y = y;
                this.size = Math.random() * 1.8 + 0.3;
                this.density = (Math.random() * 25) + 2;
                this.vx = (Math.random() - 0.5) * 0.15;
                this.vy = (Math.random() - 0.5) * 0.15;
            }
            draw() {
                ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
                ctx.beginPath(); ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2); ctx.fill();
            }
            update() {
                // Apply constant drift
                this.x += this.vx; this.y += this.vy;

                // Screen wrap logic
                if (this.x < 0) this.x = canvas.width;
                if (this.x > canvas.width) this.x = 0;
                if (this.y < 0) this.y = canvas.height;
                if (this.y > canvas.height) this.y = 0;

                // Permanent Displacement logic
                let dx = mouse.x - this.x;
                let dy = mouse.y - this.y;
                let distance = Math.sqrt(dx * dx + dy * dy);
                
                if (distance < mouse.radius) {
                    let force = (mouse.radius - distance) / mouse.radius;
                    let pushX = (dx / distance) * force * this.density;
                    let pushY = (dy / distance) * force * this.density;
                    this.x -= pushX;
                    this.y -= pushY;
                }
            }
        }

        function initParticles() {
            particles = [];
            const numberOfParticles = (canvas.width * canvas.height) / 9500;
            for (let i = 0; i < numberOfParticles; i++) {
                particles.push(new Particle(Math.random() * canvas.width, Math.random() * canvas.height));
            }
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => { p.update(); p.draw(); });
            requestAnimationFrame(animate);
        }

        window.addEventListener('resize', resize);
        resize(); animate();

        // Mouse Move Handler for Cursor and Stars
        window.addEventListener('mousemove', (e) => {
            mouse.x = e.clientX; mouse.y = e.clientY;
            if (dot && outline) {
                dot.style.left = `${e.clientX}px`; dot.style.top = `${e.clientY}px`;
                outline.animate({ left: `${e.clientX}px`, top: `${e.clientY}px` }, { duration: 500, fill: "forwards" });
            }
        });

        // Hover effect for interactive elements
        const targets = document.querySelectorAll('a, button, .social-icon, .tag');
        targets.forEach(t => {
            t.addEventListener('mouseenter', () => outline.classList.add('hovering'));
            t.addEventListener('mouseleave', () => outline.classList.remove('hovering'));
        });
    }

    // --- Typewriter & Toggle (Simplified for readability) ---
    const titleEl = document.getElementById('typewriter-title');
    if (titleEl) {
        const text = titleEl.getAttribute('data-text') || "";
        titleEl.textContent = ""; 
        let i = 0;
        function type() { if (i < text.length) { titleEl.textContent += text.charAt(i++); setTimeout(type, 85); } }
        setTimeout(type, 400);
    }

    const copyBtn = document.querySelector('.copy-email-btn');
    if (copyBtn) {
        copyBtn.addEventListener('click', () => {
            const email = copyBtn.getAttribute('data-email');
            if (email) {
                navigator.clipboard.writeText(email);
                const originalTip = copyBtn.getAttribute('data-tooltip');
                copyBtn.setAttribute('data-tooltip', 'Copied!');
                setTimeout(() => copyBtn.setAttribute('data-tooltip', originalTip || ""), 2000);
            }
        });
    }

    const toggleBtn = document.getElementById('toggle-skills');
    const panel = document.getElementById('skills-panel');
    const ctaText = document.getElementById('cta-text');
    if (toggleBtn && panel && ctaText) {
        toggleBtn.addEventListener('click', () => {
            const isOpen = panel.classList.toggle('active');
            toggleBtn.classList.toggle('is-open');
            ctaText.textContent = isOpen ? "Hide my skills" : "Click to view my skills";
        });
    }
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>