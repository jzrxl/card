---
const {name, position, aboutMe, linkedin, github, facebook, email, cvLink, profileImage } = Astro.props;
import '../styles/card.css';
---

<script 
  defer 
  src="https://cloud.umami.is/script.js" 
  data-website-id="723aea2c-5bef-4955-95e3-f85070987f2c"
></script>

<div class="cursor-dot"></div>
<div class="cursor-outline"></div>

<div class="container">
    <div class="warning-wrapper">
      <div id="force-dark-warning" class="force-dark-msg">
        <span>⚠️ Disable "Force Dark Mode" for the best experience.</span>
        <button id="close-warning" class="close-btn">&times;</button>
      </div>
    </div>

    <div class="main-wrapper">
        <div class="card-container">
            <div class="image">
                <img src={profileImage} alt={name}>
            </div>
            <div class="descripcion">
                <div class="name-status">
                    <h1>{name}</h1>
                    <span class="status-pulse" title="Available for work"></span>
                </div>
                <h2>{position}</h2>
                <p set:html={aboutMe}></p>
                
                <div class="footer-row">
                    <div class="icons">
                        {facebook && <a href={facebook} class="hover-text" target="_blank"><span class="tooltip-text">Facebook</span><i class="bi bi-facebook"></i></a>}
                        {github && <a href={github} class="hover-text" target="_blank"><span class="tooltip-text">GitHub</span><i class="bi bi-github"></i></a>}
                        {linkedin && <a href={linkedin} class="hover-text" target="_blank"><span class="tooltip-text">LinkedIn</span><i class="bi bi-linkedin"></i></a>}
                        {cvLink && (
                            <a href={cvLink} id="cv-download-link" class="hover-text" target="_blank">
                                <span class="tooltip-text" id="cv-tooltip">Resume</span>
                                <i class="bi bi-file-earmark-arrow-down"></i>
                            </a>
                        )}
                        {email && (
                            <div class="hover-text copy-email-btn" data-email={email}>
                                <span class="tooltip-text" id="copy-tooltip">Click to Copy</span>
                                <i class="bi bi-envelope-at-fill"></i>
                            </div>
                        )}
                    </div>

                    <button id="toggle-skills" class="skills-toggle-btn">
                        Skills <i class="bi bi-chevron-down" id="arrow-icon"></i>
                    </button>
                </div>
            </div>
        </div>

        <div id="skills-panel" class="skills-panel">
            <div class="skills-header-mobile">
                <h3>Technical Skills</h3>
                <button id="close-skills-mobile" class="close-panel-btn">&times;</button>
            </div>
            <div class="tech-stack-grid">
                <span class="tag">Hardware</span>
                <span class="tag">Windows</span>
                <span class="tag">Networking</span>
                <span class="tag">Software</span>
                <span class="tag">Troubleshooting</span>
                <span class="tag">SysConfig</span>
                <span class="tag">OS</span>
                <span class="tag">LAN</span>
                <span class="tag">Connectivity</span>
                <span class="tag">Device Setup</span>
                <span class="tag">Optimization</span>
                <span class="tag">IT Support</span>
                <span class="tag">Systems</span>
            </div>
        </div>
    </div>
    <div id="overlay" class="overlay"></div>
</div>

<script>
  declare global { interface Window { umami: any; } }

  function initAll() {
    const toggleBtn = document.getElementById('toggle-skills');
    const closeBtnMobile = document.getElementById('close-skills-mobile');
    const panel = document.getElementById('skills-panel');
    const arrow = document.getElementById('arrow-icon');
    const overlay = document.getElementById('overlay');

    const togglePanel = (forceClose = false) => {
        const isOpen = forceClose ? false : panel?.classList.toggle('active');
        if (forceClose) panel?.classList.remove('active');
        
        if (arrow) arrow.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
        overlay?.classList.toggle('active', !!isOpen);
        
        if (isOpen && window.umami) window.umami.track('Skills Expanded');
    };

    if (toggleBtn) toggleBtn.onclick = () => togglePanel();
    if (closeBtnMobile) closeBtnMobile.onclick = () => togglePanel(true);
    if (overlay) overlay.onclick = () => togglePanel(true);

    // --- CURSOR LOGIC ---
    const dot = document.querySelector('.cursor-dot') as HTMLElement;
    const outline = document.querySelector('.cursor-outline') as HTMLElement;
    if (dot && outline) {
        window.onmousemove = (e) => {
            dot.style.left = `${e.clientX}px`;
            dot.style.top = `${e.clientY}px`;
            outline.animate({ left: `${e.clientX}px`, top: `${e.clientY}px` }, { duration: 500, fill: "forwards" });
        };
    }

    // --- DARK MODE DETECTION ---
    const warning = document.getElementById('force-dark-warning');
    if (warning && localStorage.getItem('hideForceDarkWarning') !== 'true') {
        const testDiv = document.createElement('div');
        testDiv.style.cssText = "background-color: rgb(255, 255, 255); position: absolute; visibility: hidden;";
        document.body.appendChild(testDiv);
        setTimeout(() => {
            if (window.getComputedStyle(testDiv).backgroundColor !== 'rgb(255, 255, 255)') warning.style.display = 'flex';
            document.body.removeChild(testDiv);
        }, 300);
    }
    
    document.getElementById('close-warning')?.addEventListener('click', () => {
        if (warning) warning.style.display = 'none';
        localStorage.setItem('hideForceDarkWarning', 'true');
    });

    // --- EMAIL LOGIC ---
    const copyBtn = document.querySelector('.copy-email-btn');
    const copyTooltip = document.getElementById('copy-tooltip');
    if (copyBtn instanceof HTMLElement && copyTooltip) {
      copyBtn.onclick = () => {
        const email = copyBtn.getAttribute('data-email');
        if (email) {
          navigator.clipboard.writeText(email).then(() => {
            copyTooltip.innerText = "Copied!";
            if (window.umami) window.umami.track('Email Copied');
            setTimeout(() => { copyTooltip.innerText = "Click to Copy"; }, 2000);
          });
        }
      };
    }
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>