---
const {name, position, aboutMe, linkedin, github, facebook, email, cvLink, profileImage } = Astro.props;
import '../styles/card.css';
---

<div class="cursor-dot"></div>
<div class="cursor-outline"></div>

<div class="container">
    <div id="force-dark-warning" class="force-dark-msg">
      <span>⚠️ Please disable "Force Dark Mode" for the best experience.</span>
      <button id="close-warning" class="close-btn">&times;</button>
    </div>

    <div class="main-wrapper reveal">
        <div class="card-container">
            <div class="descripcion">
                <div class="name-status">
                    <h1>{name}</h1>
                    <span class="status-pulse" title="Available for work"></span>
                </div>
                
                <h2 id="typewriter-title" class="job-title" data-text={position}></h2>
                
                <p set:html={aboutMe}></p>
                
                <div class="social-footer">
                    <div class="icons-grid">
                        {facebook && (
                            <div class="icon-item">
                                <a href={facebook} class="hover-text" target="_blank">
                                    <span class="tooltip-text">Facebook</span>
                                    <i class="bi bi-facebook"></i>
                                </a>
                                <span class="icon-label">Facebook</span>
                            </div>
                        )}
                        {github && (
                            <div class="icon-item">
                                <a href={github} class="hover-text" target="_blank">
                                    <span class="tooltip-text">GitHub</span>
                                    <i class="bi bi-github"></i>
                                </a>
                                <span class="icon-label">GitHub</span>
                            </div>
                        )}
                        {linkedin && (
                            <div class="icon-item">
                                <a href={linkedin} class="hover-text" target="_blank">
                                    <span class="tooltip-text">LinkedIn</span>
                                    <i class="bi bi-linkedin"></i>
                                </a>
                                <span class="icon-label">LinkedIn</span>
                            </div>
                        )}
                        {cvLink && (
                            <div class="icon-item">
                                <a href={cvLink} class="hover-text" target="_blank">
                                    <span class="tooltip-text">Resume</span>
                                    <i class="bi bi-file-earmark-arrow-down"></i>
                                </a>
                                <span class="icon-label">Resume</span>
                            </div>
                        )}
                        {email && (
                            <div class="icon-item">
                                <div class="hover-text copy-email-btn" data-email={email}>
                                    <span class="tooltip-text">Copy</span>
                                    <i class="bi bi-envelope-at-fill"></i>
                                </div>
                                <span class="icon-label">Email</span>
                            </div>
                        )}
                    </div>
                </div>
            </div>
            <div class="image">
                <img src={profileImage} alt={name}>
            </div>
        </div>

        <div id="skills-panel" class="skills-panel">
            <div class="panel-inner">
                <div class="tech-stack">
                    <span class="tag">Hardware</span>
                    <span class="tag">Windows</span>
                    <span class="tag">Networking</span>
                    <span class="tag">Software</span>
                    <span class="tag">Troubleshooting</span>
                    <span class="tag">SysConfig</span>
                    <span class="tag">OS</span>
                    <span class="tag">LAN</span>
                    <span class="tag">Connectivity</span>
                    <span class="tag">Device Setup</span>
                    <span class="tag">Optimization</span>
                    <span class="tag">IT Support</span>
                    <span class="tag">Systems</span>
                </div>
            </div>
        </div>

        <div class="trigger-wrapper">
            <button id="toggle-skills" class="arrow-btn" aria-label="Toggle Skills">
                <i class="bi bi-chevron-down" id="arrow-icon"></i>
            </button>
        </div>
    </div>

    <footer class="git-footer">
        <code>git push origin main</code>
    </footer>
</div>

<script>
  function initAll() {
    // 1. TYPEWRITER (Fixed Logic)
    const titleEl = document.getElementById('typewriter-title');
    const text = titleEl?.getAttribute('data-text') || "";
    if (titleEl && titleEl.innerText === "") {
        let i = 0;
        function type() {
            if (i < text.length) {
                // Using textContent and incremental substring to preserve spaces
                titleEl!.textContent = text.substring(0, i + 1);
                i++;
                setTimeout(type, 80);
            }
        }
        setTimeout(type, 600);
    }

    // 2. CURSOR
    const dot = document.querySelector('.cursor-dot') as HTMLElement;
    const outline = document.querySelector('.cursor-outline') as HTMLElement;
    if (dot && outline) {
        window.onmousemove = (e) => {
            dot.style.left = `${e.clientX}px`;
            dot.style.top = `${e.clientY}px`;
            outline.animate({ left: `${e.clientX}px`, top: `${e.clientY}px` }, { duration: 500, fill: "forwards" });
        };
    }

    // 3. SKILLS TOGGLE
    const toggleBtn = document.getElementById('toggle-skills');
    const panel = document.getElementById('skills-panel');
    const arrow = document.getElementById('arrow-icon');
    if (toggleBtn && panel && arrow) {
        toggleBtn.onclick = () => {
            const isOpen = panel.classList.toggle('active');
            arrow.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
        };
    }

    // 4. DARK MODE WARNING (Fixed Squiggle)
    const warning = document.getElementById('force-dark-warning');
    const closeBtn = document.getElementById('close-warning');
    
    if (warning && localStorage.getItem('hideForceDarkWarning') !== 'true') {
        const testDiv = document.createElement('div');
        testDiv.style.cssText = "background-color: rgb(255, 255, 255); position: absolute; visibility: hidden;";
        document.body.appendChild(testDiv);
        setTimeout(() => {
            if (window.getComputedStyle(testDiv).backgroundColor !== 'rgb(255, 255, 255)') {
                warning.style.display = 'flex';
            }
            document.body.removeChild(testDiv);
        }, 300);
    }

    if (closeBtn && warning) {
        closeBtn.addEventListener('click', () => {
            warning.style.display = 'none';
            localStorage.setItem('hideForceDarkWarning', 'true');
        });
    }

    // 5. REVEAL
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('active');
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>