---
const {name, position, aboutMe, linkedin, github, facebook, email, cvLink, profileImage } = Astro.props;
import '../styles/card.css';
---

<canvas id="snowCanvas"></canvas>

<div class="cursor-dot"></div>
<div class="cursor-outline"></div>
<div class="bg-glow"></div>

<div class="container">
    <div class="main-wrapper reveal">
        <div class="card-container">
            <div class="descripcion">
                <div class="name-status">
                    <h1>{name}</h1>
                </div>
                
                <div class="title-container">
                    <h2 id="typewriter-title" data-text={position}></h2>
                </div>
                
                <p set:html={aboutMe}></p>
                
                <div class="social-footer">
                    <div class="icons">
                        {facebook && <a href={facebook} class="social-icon" target="_blank" aria-label="Facebook"><i class="bi bi-facebook"></i></a>}
                        {github && <a href={github} class="social-icon" target="_blank" aria-label="GitHub"><i class="bi bi-github"></i></a>}
                        {linkedin && <a href={linkedin} class="social-icon" target="_blank" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>}
                        {cvLink && <a href={cvLink} class="social-icon" target="_blank" aria-label="Resume"><i class="bi bi-file-earmark-arrow-down"></i></a>}
                        {email && (
                            <div class="social-icon copy-email-btn" data-email={email} role="button">
                                <i class="bi bi-envelope-at-fill"></i>
                            </div>
                        )}
                    </div>
                </div>
            </div>
            <div class="image">
                <img src={profileImage} alt={name}>
            </div>
        </div>

        <div id="skills-panel" class="skills-panel">
            <div class="panel-inner">
                <div class="tech-stack">
                    <span class="tag">Hardware</span>
                    <span class="tag">Windows</span>
                    <span class="tag">Networking</span>
                    <span class="tag">Software</span>
                    <span class="tag">Troubleshooting</span>
                    <span class="tag">SysConfig</span>
                    <span class="tag">OS</span>
                    <span class="tag">LAN</span>
                    <span class="tag">IT Support</span>
                </div>
            </div>
        </div>

        <div class="trigger-wrapper">
            <button id="toggle-skills" class="skills-cta">
                <i class="bi bi-chevron-down arrow-left"></i>
                <span id="cta-text">Click to view my skills</span>
                <i class="bi bi-chevron-down arrow-right"></i>
            </button>
        </div>
    </div>

    <footer class="git-footer">
        <code>git push origin main</code>
    </footer>
</div>

<script>
  function initAll() {
    // --- Console Easter Egg ---
    console.log("%cWelcome... to Portfolio-com.", "font-weight:bold; font-size:20px; color:#12a89c;");

    // --- Snow Particles ---
    const canvas = document.getElementById('snowCanvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    let particles: any[] = [];
    const mouse = { x: -1000, y: -1000, radius: 120 };

    function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }

    class Particle {
        x: number; y: number; size: number; speedX: number; speedY: number; density: number;
        constructor() {
            this.x = Math.random() * canvas.width;
            this.y = Math.random() * canvas.height;
            this.size = Math.random() * 2 + 1;
            this.speedX = Math.random() * 1 - 0.5;
            this.speedY = Math.random() * 1 + 0.3;
            this.density = (Math.random() * 20) + 1;
        }
        update() {
            this.x += this.speedX;
            this.y += this.speedY;
            if (this.y > canvas.height) { this.y = -10; this.x = Math.random() * canvas.width; }
            
            let dx = mouse.x - this.x;
            let dy = mouse.y - this.y;
            let distance = Math.sqrt(dx*dx + dy*dy);
            if (distance < mouse.radius) {
                const force = (mouse.radius - distance) / mouse.radius;
                this.x -= (dx / distance) * force * this.density;
                this.y -= (dy / distance) * force * this.density;
            }
        }
        draw() {
            ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => { p.update(); p.draw(); });
        requestAnimationFrame(animate);
    }

    window.onmousemove = (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
        // Also update cursor effects
        const dot = document.querySelector('.cursor-dot') as HTMLElement;
        const outline = document.querySelector('.cursor-outline') as HTMLElement;
        if (dot && outline) {
            dot.style.left = `${e.clientX}px`;
            dot.style.top = `${e.clientY}px`;
            outline.animate({ left: `${e.clientX}px`, top: `${e.clientY}px` }, { duration: 500, fill: "forwards" });
        }
    };

    resize();
    particles = Array.from({length: 100}, () => new Particle());
    animate();

    // --- Other UI Logic ---
    const toggleBtn = document.getElementById('toggle-skills');
    const panel = document.getElementById('skills-panel');
    const ctaText = document.getElementById('cta-text');
    if (toggleBtn && panel && ctaText) {
        toggleBtn.onclick = () => {
            const isOpen = panel.classList.toggle('active');
            toggleBtn.classList.toggle('is-open');
            ctaText.textContent = isOpen ? "Hide my skills" : "Click to view my skills";
        };
    }

    const titleEl = document.getElementById('typewriter-title');
    if (titleEl && titleEl.textContent === "") {
        const text = titleEl.getAttribute('data-text') || "";
        let i = 0;
        const type = () => {
            if (i <= text.length) {
                titleEl.textContent = text.slice(0, i);
                i++;
                setTimeout(type, 70);
            }
        };
        setTimeout(type, 500);
    }
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>